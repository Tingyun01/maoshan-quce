.container { position: relative; min-height: 100vh; padding: 0 28rpx 40rpx; display: flex; flex-direction: column; align-items: center; background: linear-gradient(175deg, #3D5E4E 0%, #2A3D35 38%, #1A2D25 100%); }
.bg-bagua { position: fixed; right: -40rpx; bottom: -40rpx; width: 300rpx; height: 300rpx; opacity: 0.05; z-index: 0; pointer-events: none; }

/* ===== 结果卡片（画卷展开动效） ===== */
.result-card { width: 100%; padding: 36rpx 28rpx 24rpx; background: rgba(245,240,230,0.93); border-radius: 24rpx; display: flex; flex-direction: column; align-items: center; margin-bottom: 18rpx; position: relative; z-index: 1; box-shadow: 0 4rpx 24rpx rgba(45,26,26,0.06); opacity: 0; transform: scale(0.9); transition: all 0.55s cubic-bezier(0.34, 1.56, 0.64, 1); }
.result-card.show { opacity: 1; transform: scale(1); }

.rank-badge { font-size: 20rpx; color: #FFF8F5; background: linear-gradient(135deg, var(--gold), #A0522D); padding: 6rpx 24rpx; border-radius: 20rpx; font-weight: 600; letter-spacing: 2rpx; margin-bottom: 12rpx; animation: flashScale 0.5s ease 0.6s both; }
.result-icon { font-size: 72rpx; margin-bottom: 8rpx; }
.result-type { font-size: 40rpx; font-weight: 800; color: var(--charcoal); margin-bottom: 4rpx; }
.result-summary { font-size: 26rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.result-divider { width: 60rpx; height: 2rpx; background: linear-gradient(90deg, transparent, var(--gold), transparent); margin-bottom: 14rpx; }

.rarity-tag { font-size: 20rpx; color: #A0522D; background: rgba(160,82,45,0.08); padding: 4rpx 20rpx; border-radius: 20rpx; margin-bottom: 12rpx; font-weight: 500; }

/* 段子式tagline */
.tagline { font-size: 26rpx; color: var(--gold); text-align: center; padding: 12rpx 20rpx; background: rgba(201,169,110,0.08); border-radius: 16rpx; margin-bottom: 16rpx; width: 100%; line-height: 1.6; font-weight: 500; }
.tagline:active { opacity: 0.7; }

.result-brief { font-size: 24rpx; color: var(--charcoal-light); line-height: 1.8; text-align: left; padding: 0 4rpx; width: 100%; }

/* 双视角描述（网易云灵感） */
.dual-perspective { width: 100%; margin-top: 18rpx; padding: 18rpx; background: rgba(201,169,110,0.06); border-radius: 16rpx; border: 1rpx solid rgba(201,169,110,0.1); }
.dp-row { display: flex; align-items: flex-start; gap: 10rpx; margin-bottom: 10rpx; }
.dp-row:last-child { margin-bottom: 0; }
.dp-icon { font-size: 26rpx; flex-shrink: 0; }
.dp-text { font-size: 22rpx; color: var(--charcoal-light); line-height: 1.6; }
.dp-label-text { font-weight: 600; color: var(--charcoal); }

/* 优缺点 */
.pros-cons { width: 100%; margin-top: 18rpx; padding: 16rpx 18rpx; background: rgba(45,26,26,0.02); border-radius: 16rpx; }
.pc-label { font-size: 22rpx; font-weight: 600; color: var(--charcoal); display: block; margin-bottom: 8rpx; }
.pc-pros { font-size: 24rpx; color: #7A9E7A; display: block; margin-bottom: 6rpx; padding: 6rpx 0 6rpx 20rpx; position: relative; }
.pc-pros::before { content: '▸'; position: absolute; left: 0; color: #7A9E7A; }
.pc-cons { font-size: 24rpx; color: #A0522D; display: block; padding: 6rpx 0 6rpx 20rpx; position: relative; }
.pc-cons::before { content: '▸'; position: absolute; left: 0; color: #A0522D; }

.career-tip { width: 100%; font-size: 24rpx; color: var(--text-secondary); margin-top: 14rpx; padding: 12rpx 0 4rpx; }

/* 评分条 */
.ratings-bar { width: 100%; margin-top: 18rpx; padding-top: 18rpx; border-top: 1rpx solid rgba(45,26,26,0.04); }
.rating-item { display: flex; align-items: center; gap: 10rpx; margin-bottom: 12rpx; }
.rating-label { font-size: 22rpx; color: var(--text-secondary); width: 4em; flex-shrink: 0; }
.rating-track { flex: 1; height: 14rpx; background: rgba(45,26,26,0.04); border-radius: 7rpx; overflow: hidden; }
.rating-fill { height: 100%; background: linear-gradient(90deg, var(--gold), #FFB88C); border-radius: 7rpx; transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); }
.rating-value { font-size: 22rpx; color: var(--gold); width: 3.5em; text-align: right; flex-shrink: 0; font-weight: 600; }

/* 一键复制话题 */
.copy-bar { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 16rpx 0; background: rgba(201,169,110,0.08); border: 1rpx dashed rgba(201,169,110,0.22); border-radius: 18rpx; margin-bottom: 14rpx; position: relative; z-index: 1; }
.copy-bar:active { background: rgba(201,169,110,0.12); }
.copy-icon { font-size: 26rpx; }
.copy-text { font-size: 26rpx; color: var(--gold); font-weight: 500; }

/* AI分析 */
.ai-section { width: 100%; padding: 22rpx 20rpx; background: rgba(245,240,230,0.65); border-radius: 20rpx; margin-bottom: 16rpx; position: relative; z-index: 1; }
.ai-title { font-size: 26rpx; font-weight: 600; color: var(--charcoal); display: block; margin-bottom: 8rpx; }
.ai-content { font-size: 24rpx; color: var(--charcoal-light); line-height: 1.7; }
.unlock-btn { width: 100%; display: flex; align-items: center; justify-content: center; gap: 10rpx; padding: 22rpx 0; background: linear-gradient(135deg, var(--gold), #A0522D); border-radius: 20rpx; margin-bottom: 14rpx; position: relative; z-index: 1; animation: btnGlow 2.5s ease-in-out infinite; }
.unlock-btn:active { opacity: 0.85; }
.unlock-icon { font-size: 28rpx; }
.unlock-text { font-size: 26rpx; color: #FFF8F5; font-weight: 600; letter-spacing: 2rpx; }

.share-row { width: 100%; display: flex; gap: 10rpx; margin-bottom: 12rpx; position: relative; z-index: 1; }
.share-btn { flex: 1; padding: 16rpx 0; text-align: center; font-size: 24rpx; color: rgba(245,240,230,0.6); background: rgba(245,240,230,0.06); border: 1rpx solid rgba(245,240,230,0.04); border-radius: 18rpx; }
.share-btn:active { background: rgba(245,240,230,0.1); }
.poster-btn { color: var(--gold); }

/* 好友对比入口 */
.compare-entry { width: 100%; display: flex; align-items: center; gap: 8rpx; padding: 20rpx 20rpx; background: rgba(245,240,230,0.93); border-radius: 18rpx; margin-bottom: 12rpx; position: relative; z-index: 1; box-shadow: 0 2rpx 12rpx rgba(45,26,26,0.04); }
.compare-entry:active { opacity: 0.8; }
.ce-icon { font-size: 30rpx; }
.ce-text { flex: 1; font-size: 26rpx; color: var(--charcoal); font-weight: 500; }
.ce-arrow { font-size: 30rpx; color: var(--text-muted); }

.retest { display: none; }
/* 再来一测快捷卡片 */
.retest-card {
  width: 100%; display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 24rpx; margin-bottom: 12rpx;
  background: linear-gradient(135deg, rgba(201,169,110,0.12), rgba(160,130,90,0.06));
  border: 1.5rpx solid rgba(201,169,110,0.2); border-radius: 20rpx;
  position: relative; z-index: 1; animation: cardPopIn 0.5s ease-out 0.3s both;
}
.retest-card:active { background: rgba(201,169,110,0.18); transform: scale(0.97); }
.rc-left { display: flex; align-items: center; gap: 16rpx; }
.rc-icon { font-size: 44rpx; }
.rc-texts { display: flex; flex-direction: column; gap: 4rpx; }
.rc-title { font-size: 28rpx; font-weight: 700; color: #D4BC80; letter-spacing: 2rpx; }
.rc-sub { font-size: 22rpx; color: rgba(200,210,185,0.5); }
.rc-arrow { font-size: 36rpx; color: rgba(201,169,110,0.5); font-weight: 700; }
.slogan-bottom { font-size: 24rpx; color: rgba(255,215,0,0.5); font-weight: 500; letter-spacing: 2rpx; text-align: center; padding: 8rpx 0 4rpx; margin-top: auto; position: relative; z-index: 1; }
.disclaimer { font-size: 18rpx; color: rgba(245,240,230,0.18); text-align: center; padding: 0 20rpx 24rpx; line-height: 1.5; position: relative; z-index: 1; }

/* 问道之旅通关提示 */
.journey-complete { width: 100%; margin: 20rpx 0; padding: 24rpx; background: rgba(122,158,122,0.1); border: 1rpx solid rgba(201,169,110,0.2); border-radius: 20rpx; position: relative; z-index: 1; animation: slideUp 0.5s ease-out; }
.jc-header { display: flex; align-items: center; gap: 8rpx; margin-bottom: 12rpx; }
.jc-icon { font-size: 28rpx; }
.jc-title { font-size: 26rpx; font-weight: bold; color: #C9A96E; }
.jc-level { font-size: 28rpx; font-weight: 600; color: #E8D0C0; display: block; margin-bottom: 8rpx; }
.jc-master { font-size: 22rpx; color: rgba(232,208,192,0.55); display: block; font-style: italic; margin-bottom: 8rpx; }
.jc-daojing { font-size: 22rpx; color: rgba(201,169,110,0.5); display: block; font-style: italic; margin-bottom: 16rpx; }
.jc-next { display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 16rpx; background: rgba(201,169,110,0.1); border-radius: 12rpx; }
.jc-next:active { opacity: 0.7; }
.jc-next-text { font-size: 24rpx; color: #FFD700; }
.jc-next-arrow { font-size: 28rpx; color: #FFD700; }
.jc-all-done { text-align: center; padding: 16rpx; }
.jc-all-text { font-size: 26rpx; color: #FFD700; }

/* 海报预览 */
.poster-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.3s ease; }
.poster-card { width: 520rpx; display: flex; flex-direction: column; align-items: center; position: relative; }
.poster-img { width: 520rpx; height: auto; border-radius: 14rpx; display: block; }

/* 海报品牌遮挡 — 右下角盖水印 */
.poster-brand-bar {
  position: absolute;
  bottom: 110rpx;
  right: 6rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx 8rpx 10rpx;
  background: rgba(18,24,20,0.65);
  border-radius: 10rpx 0 0 10rpx;
  backdrop-filter: blur(4px);
  z-index: 10;
}
.pb-qrcode {
  width: 34rpx;
  height: 34rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.pb-texts { display: flex; flex-direction: column; }
.pb-name { font-size: 18rpx; font-weight: bold; color: #C9A96E; line-height: 1.2; }
.pb-sub { font-size: 14rpx; color: rgba(201,169,110,0.5); line-height: 1.2; }

.poster-actions { width: 100%; display: flex; gap: 14rpx; margin-top: 18rpx; }
.poster-save { flex: 1; padding: 16rpx 0; text-align: center; font-size: 24rpx; color: #FFF8F5; background: linear-gradient(135deg, var(--gold), #A0522D); border-radius: 18rpx; font-weight: 600; }
.poster-share { flex: 1; padding: 16rpx 0; text-align: center; font-size: 24rpx; color: #FFF8F5; background: rgba(255,255,255,0.1); border-radius: 18rpx; }
.poster-close { font-size: 22rpx; color: rgba(245,240,230,0.4); padding: 16rpx; }

@keyframes fadeInUp { from { opacity: 0; transform: translateY(30rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(60rpx) scale(0.92); } to { opacity: 1; transform: translateY(0) scale(1); } }
.fade-in-up { animation: fadeInUp 0.5s ease forwards; }

/* 骨架加载 */
.poster-placeholder { width: 100%; height: 200rpx; background: linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.06), rgba(255,255,255,0.02)); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 18rpx; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
