/* ============================================================
   茅山趣测路线图 — 上半丰富内容 + 下半游戏风格小地图
   ============================================================ */

.guide-page { width:100vw; min-height:100vh; background:#E0E8E5; overflow:hidden; font-family:-apple-system,"PingFang SC","Microsoft YaHei",sans-serif; }

/* ===== 顶部栏 ===== */
.guide-topbar { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; align-items:center; justify-content:space-between; padding:0 24rpx; height:88rpx; background:linear-gradient(180deg,rgba(224,232,229,0.95) 0%,rgba(224,232,229,0.7) 100%); }
.bar-back,.bar-home { font-size:28rpx; color:#6B5B4E; padding:8rpx 12rpx; }
.bar-title { font-size:30rpx; font-weight:bold; color:#6B5B4E; letter-spacing:4rpx; }

.map-phase { position:fixed; top:0; left:0; right:0; bottom:0; padding-top:88rpx; }
.map-scroll { height:100%; }

/* ============================================================ */
/* 上半：丰富内容 */
/* ============================================================ */
.upper-half {
  padding:20rpx 28rpx 28rpx;
  background:linear-gradient(180deg,#E0E8E5 0%,#D8E0DD 50%,#D0DAD5 100%);
}

/* 问候 */
.guide-greeting { display:flex; flex-direction:column; align-items:center; gap:6rpx; margin-bottom:16rpx; }
.gg-title { font-size:30rpx; font-weight:800; color:#3A4A3E; letter-spacing:6rpx; }
.gg-sub { font-size:22rpx; color:#8A9A8A; letter-spacing:4rpx; }

/* 进度 */
.guide-steps { display:flex; flex-direction:column; gap:8rpx; margin-bottom:18rpx; }
.gs-left { display:flex; align-items:center; justify-content:space-between; }
.gs-step { font-size:24rpx; color:#5A4A3E; font-weight:600; letter-spacing:2rpx; }
.gs-done { font-size:20rpx; color:#7A9A7A; }
.gs-bar { height:6rpx; background:rgba(100,120,110,0.12); border-radius:3rpx; overflow:hidden; }
.gs-fill { height:100%; background:linear-gradient(90deg,#6a8a7a,#4a7a5a); border-radius:3rpx; transition:width 0.5s; }

/* 当前关卡大卡片 */
.current-card {
  width:100%; border-radius:22rpx; overflow:hidden; position:relative;
  box-shadow:0 6rpx 30rpx rgba(60,90,70,0.1);
  animation:cardIn 0.4s ease-out;
}
@keyframes cardIn{from{opacity:0;transform:translateY(20rpx)}to{opacity:1;transform:translateY(0)}}
.current-card:active{transform:scale(0.97)}

.cc-bg { position:absolute; top:0; left:0; right:0; bottom:0; opacity:0.22; }
.cc-content { position:relative; z-index:1; display:flex; align-items:center; gap:24rpx; padding:32rpx 28rpx; }

.cc-left { flex-shrink:0; }
.cc-icon-wrap { position:relative; width:110rpx; height:110rpx; display:flex; align-items:center; justify-content:center; }
.cc-glow { position:absolute; width:88rpx; height:88rpx; border-radius:50%; animation:glowPulse 2s ease-in-out infinite; }
@keyframes glowPulse{0%,100%{transform:scale(1);opacity:0.5}50%{transform:scale(1.2);opacity:1}}
.cc-icon { font-size:50rpx; z-index:1; }

.cc-right { flex:1; display:flex; flex-direction:column; gap:6rpx; }
.cc-name { font-size:34rpx; font-weight:800; color:#3A4A3E; letter-spacing:4rpx; }
.cc-alias { font-size:22rpx; color:#7A8A7A; letter-spacing:2rpx; }
.cc-tags { display:flex; align-items:center; gap:12rpx; margin-top:6rpx; }
.cc-tag { font-size:24rpx; color:#4a7a5a; font-weight:600; background:rgba(74,122,90,0.12); padding:6rpx 16rpx; border-radius:18rpx; }
.cc-tag-arrow { font-size:24rpx; color:#3a6a4a; font-weight:600; margin-left:auto; letter-spacing:2rpx; }

/* 下一站 */
.next-stop { margin-top:18rpx; display:flex; flex-direction:column; align-items:center; }
.ns-arrow { font-size:20rpx; color:#6a8a6a; font-weight:600; background:rgba(255,255,255,0.4); padding:4rpx 16rpx; border-radius:16rpx; margin-bottom:8rpx; letter-spacing:4rpx; }
.ns-card { width:100%; display:flex; align-items:center; gap:16rpx; padding:20rpx; background:rgba(255,255,255,0.35); border-radius:16rpx; border:1.5rpx dashed rgba(100,140,120,0.2); }
.ns-icon { font-size:32rpx; }
.ns-info { flex:1; display:flex; flex-direction:column; gap:2rpx; }
.ns-name { font-size:26rpx; font-weight:700; color:#5A4A3E; letter-spacing:2rpx; }
.ns-test { font-size:20rpx; color:#6a8a6a; }

/* 已完成景点 */
.done-zone { margin-top:18rpx; padding-top:14rpx; border-top:1rpx solid rgba(100,120,110,0.12); }
.dz-title { font-size:20rpx; color:#8A9A8A; letter-spacing:2rpx; margin-bottom:10rpx; display:block; }
.dz-scroll { display:flex; flex-direction:row; white-space:nowrap; }
.dz-item { display:inline-flex; flex-direction:column; align-items:center; gap:4rpx; margin-right:18rpx; min-width:60rpx; }
.dz-dot { width:44rpx; height:44rpx; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.dz-icon { font-size:18rpx; }
.dz-name { font-size:18rpx; color:#7A8A7A; letter-spacing:1rpx; overflow:hidden; text-overflow:ellipsis; max-width:60rpx; }

/* ============================================================ */
/* 下半：游戏风格小地图 */
/* ============================================================ */
.lower-half {
  flex:1; padding:16rpx 24rpx 40rpx;
  background:linear-gradient(180deg,#D0DAD5 0%,#C8D4CF 40%,#CED8D3 100%);
  display:flex; flex-direction:column;
}

.mm-header { display:flex; align-items:center; gap:10rpx; margin-bottom:12rpx; padding:0 4rpx; }
.mmh-title { font-size:24rpx; font-weight:700; color:#4A5A4E; letter-spacing:3rpx; }
.mmh-hint { font-size:18rpx; color:#9A8A7A; margin-left:auto; }

/* 地图框 */
.minimap-box {
  position:relative; width:100%; height:480rpx;
  border-radius:16rpx; overflow:hidden;
  background:linear-gradient(180deg,#DAE3DD 0%,#D0DBD2 40%,#C8D4CB 70%,#D0DCD3 100%);
  border:1rpx solid rgba(100,130,115,0.12);
}

/* 背景装饰 */
.mm-bg-deco { position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none; opacity:0.15; }
.mm-deco-dots { width:100%; height:100%; background-image:radial-gradient(circle,rgba(80,120,100,0.15) 1rpx,transparent 1rpx); background-size:20rpx 20rpx; }

/* 路径线 */
.mm-lines { position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:1; }
.mm-line { position:absolute; height:3rpx; background:linear-gradient(90deg,rgba(100,140,120,0.05) 0%,rgba(100,140,120,0.3) 50%,rgba(100,140,120,0.05) 100%); transform-origin:center center; border-radius:2rpx; }

/* 景点 */
.mm-spots-layer { position:absolute; top:0; left:0; width:100%; height:100%; z-index:2; }
.mm-spot { position:absolute; transform:translate(-50%,-50%); display:flex; flex-direction:column; align-items:center; gap:2rpx; }
.ms-dot { border-radius:50%; display:flex; align-items:center; justify-content:center; transition:all 0.2s; }
.ms-icon { display:flex; align-items:center; justify-content:center; width:100%; height:100%; }
.ms-name {
  font-size:18rpx; color:#5A4A3E; font-weight:700;
  background:rgba(255,255,255,0.6); padding:2rpx 6rpx; border-radius:6rpx;
  white-space:nowrap; max-width:88rpx; overflow:hidden; text-overflow:ellipsis;
}
.ms-current .ms-name { max-width:120rpx !important; }

/* 当前站点 */
.ms-current .ms-dot { animation:msPulse 2s ease-in-out infinite; }
@keyframes msPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.18)}}
.ms-name-cur { font-size:20rpx !important; color:#2A5A3A !important; font-weight:800 !important; max-width:120rpx !important; }

/* 已完成 */
.ms-done .ms-dot { opacity:0.35; }
.ms-done .ms-name { color:#9A8A7A; }

/* 锁定 */
.ms-locked { opacity:0.25; }
.ms-locked .ms-name { color:#aaa; background:rgba(200,200,200,0.2); }

/* 底部 */
.mm-footer { text-align:center; padding:14rpx 0 6rpx; }
.mm-footer-text { font-size:22rpx; color:#8A7A6A; letter-spacing:2rpx; }

/* ============================================================ */
/* 副本地图 */
/* ============================================================ */
.dungeon-container { position:relative; width:100%; min-height:1200rpx; background:linear-gradient(180deg,#1a2a22 0%,#1e3028 20%,#22352c 40%,#1e3028 60%,#1a2a22 80%,#16261e 100%); overflow:hidden; }
.dungeon-bg { position:absolute; top:0; left:0; right:0; bottom:0; opacity:0.10; background-image:radial-gradient(circle,rgba(120,200,160,0.15) 1rpx,transparent 1rpx); background-size:24rpx 24rpx; }
.dungeon-header { position:relative; z-index:3; display:flex; flex-direction:column; align-items:center; padding:40rpx 0 24rpx; }
.dungeon-title { font-size:36rpx; font-weight:bold; color:#b8dcc8; letter-spacing:6rpx; text-shadow:0 0 20rpx rgba(74,150,120,0.3); }
.dungeon-sub { font-size:22rpx; color:rgba(180,220,200,0.4); margin-top:6rpx; letter-spacing:4rpx; }
.dungeon-exit-btn { position:sticky; bottom:60rpx; z-index:5; display:flex; align-items:center; justify-content:center; padding:20rpx 0; margin:40rpx 100rpx 80rpx; background:rgba(100,160,130,0.2); border:1.5rpx solid rgba(100,160,130,0.3); border-radius:40rpx; }
.dungeon-exit-btn text { font-size:28rpx; color:#b8dcc8; letter-spacing:6rpx; }
.dungeon-sub-spot .sl-name { color:#c0d8c8 !important; }
.paths-layer { position:absolute; top:0; left:0; width:100%; height:100%; z-index:1; pointer-events:none; }
.path-line { position:absolute; height:4rpx; background:linear-gradient(90deg,rgba(100,130,115,0.1) 0%,rgba(100,130,115,0.5) 50%,rgba(100,130,115,0.1) 100%); transform-origin:center center; }
.line-dungeon { height:4rpx; background:linear-gradient(90deg,rgba(74,107,90,0.1) 0%,rgba(74,107,90,0.6) 50%,rgba(74,107,90,0.1) 100%); box-shadow:0 0 8rpx rgba(74,107,90,0.2); }
.spots-layer { position:absolute; top:0; left:0; width:100%; height:100%; z-index:2; }
.map-spot { position:absolute; display:flex; flex-direction:column; align-items:center; transform:translate(-50%,-50%); width:160rpx; }
.spot-dot { border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:6rpx; }
.sd-icon { display:flex; align-items:center; justify-content:center; width:100%; height:100%; }
.spot-label { display:flex; flex-direction:column; align-items:center; gap:2rpx; text-align:center; }
.sl-name { letter-spacing:2rpx; max-width:140rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-weight:600; font-size:22rpx; }
.spot-current .spot-dot { animation:dungeonCurrentPulse 2s ease-in-out infinite; border:3rpx solid rgba(255,255,255,0.5); }
.spot-future { opacity:0.25; }
@keyframes dungeonCurrentPulse{0%,100%{transform:scale(1);box-shadow:0 0 30rpx rgba(60,120,80,0.4)}50%{transform:scale(1.12);box-shadow:0 0 60rpx rgba(60,120,80,0.7)}}

/* ============================================================ */
/* 景点详情 */
/* ============================================================ */
.spot-phase { position:fixed; top:0; left:0; right:0; bottom:0; z-index:200; background:#E0E8E5; display:flex; flex-direction:column; animation:spotEnter 0.35s ease-out; }
@keyframes spotEnter{from{opacity:0;transform:scale(1.05)}to{opacity:1;transform:scale(1)}}
.spot-back { position:absolute; top:48rpx; left:24rpx; z-index:10; font-size:28rpx; color:#5A4A3E; padding:10rpx 20rpx; background:rgba(255,255,255,0.7); border-radius:30rpx; }
.spot-scene { flex:1; display:flex; flex-direction:column; align-items:center; padding:120rpx 40rpx 40rpx; overflow-y:auto; position:relative; }
.scene-aura { position:absolute; top:20rpx; width:400rpx; height:400rpx; background:radial-gradient(circle,rgba(180,150,120,0.06) 0%,transparent 70%); border-radius:50%; pointer-events:none; }
.scene-icon-wrap { position:relative; width:160rpx; height:160rpx; display:flex; align-items:center; justify-content:center; margin-bottom:32rpx; }
.scene-icon-glow { position:absolute; width:140rpx; height:140rpx; border-radius:50%; }
.scene-icon { font-size:72rpx; z-index:1; animation:iconFloat 3s ease-in-out infinite; }
@keyframes iconFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-10rpx)}}
.scene-info { display:flex; flex-direction:column; align-items:center; gap:10rpx; margin-bottom:32rpx; }
.scene-name { font-size:44rpx; font-weight:bold; color:#5A4A3E; letter-spacing:6rpx; }
.scene-alias { font-size:26rpx; color:#9A8A7A; }
.scene-zone-tag { font-size:22rpx; color:#8B7A6A; padding:4rpx 20rpx; background:rgba(139,111,92,0.08); border-radius:20rpx; margin-top:4rpx; }
.scene-desc { font-size:28rpx; color:#6B5B4E; text-align:center; line-height:1.7; max-width:600rpx; margin-top:8rpx; }
.scene-image { width:100%; max-width:640rpx; height:360rpx; border-radius:20rpx; margin-bottom:32rpx; border:2rpx solid rgba(100,120,110,0.15); box-shadow:0 6rpx 24rpx rgba(0,0,0,0.08); object-fit:cover; }
.scene-story { width:100%; max-width:640rpx; padding:28rpx 32rpx; background:rgba(255,255,255,0.6); border-radius:20rpx; border:1rpx solid rgba(139,111,92,0.12); margin-bottom:32rpx; }
.story-divider { font-size:24rpx; color:#8B7A6A; margin-bottom:12rpx; }
.story-text { font-size:26rpx; color:#6B5B4E; line-height:1.8; }
.scene-test-card { width:100%; max-width:640rpx; padding:32rpx; border-radius:24rpx; border-width:2rpx; display:flex; flex-direction:column; align-items:center; gap:16rpx; background:rgba(255,255,255,0.5); }
.test-card-header { display:flex; align-items:center; gap:12rpx; }
.test-card-icon { font-size:36rpx; }
.test-card-name { font-size:32rpx; font-weight:bold; color:#5A4A3E; letter-spacing:4rpx; }
.test-card-brief { font-size:26rpx; color:#7A6A5A; text-align:center; }
.test-enter-btn { width:400rpx; height:80rpx; line-height:80rpx; text-align:center; font-size:30rpx; font-weight:bold; color:#fff; border-radius:40rpx; border:none; letter-spacing:4rpx; box-shadow:0 4rpx 16rpx rgba(139,111,92,0.2); }
.test-enter-btn:active{transform:scale(0.95)}
.poetry-scroll { width:100%;max-width:640rpx;margin-bottom:32rpx;padding:36rpx 32rpx;background:linear-gradient(180deg,rgba(200,220,230,0.25) 0%,rgba(230,240,225,0.2) 30%,rgba(200,220,230,0.25) 100%);border:1.5rpx solid rgba(120,160,180,0.2);border-radius:20rpx; }
.poetry-header { display:flex;align-items:center;gap:14rpx;margin-bottom:16rpx; }
.poetry-icon { font-size:40rpx; }
.poetry-title-wrap { display:flex;flex-direction:column;gap:2rpx; }
.poetry-title { font-size:34rpx;font-weight:bold;color:#4A5A5C;letter-spacing:6rpx; }
.poetry-author { font-size:22rpx;color:#7A8A84; }
.poetry-preface { font-size:24rpx;color:#6A7A74;line-height:1.8;display:block;margin-bottom:12rpx;font-style:italic; }
.poetry-divider { width:60%;height:1rpx;background:linear-gradient(90deg,transparent,rgba(120,160,180,0.3),transparent);margin:16rpx auto; }
.poetry-body { display:flex;flex-direction:column;gap:6rpx;padding:0 8rpx; }
.poetry-line { font-size:26rpx;color:#4A5A5C;line-height:2;letter-spacing:4rpx;text-align:center; }
.monkey-zone { width:100%;max-width:640rpx;margin-bottom:32rpx; }
.monkey-banner { display:flex;flex-direction:column;align-items:center;gap:8rpx;padding:24rpx;background:linear-gradient(135deg,rgba(220,180,130,0.2),rgba(200,160,120,0.1));border:1.5rpx solid rgba(200,160,120,0.3);border-radius:20rpx;margin-bottom:20rpx; }
.monkey-banner-icon { font-size:44rpx;letter-spacing:8rpx; }
.monkey-banner-text { font-size:28rpx;font-weight:bold;color:#7A5A3E;letter-spacing:4rpx; }
.monkey-cards { display:flex;gap:12rpx;justify-content:center;flex-wrap:wrap;margin-bottom:20rpx; }
.monkey-card { display:flex;flex-direction:column;align-items:center;gap:6rpx;padding:16rpx 20rpx;background:rgba(255,255,255,0.5);border:1rpx solid rgba(139,111,92,0.15);border-radius:16rpx;min-width:100rpx;animation:monkeyBounce 2s ease-in-out infinite; }
.monkey-card:nth-child(2){animation-delay:0.2s}.monkey-card:nth-child(3){animation-delay:0.4s}.monkey-card:nth-child(4){animation-delay:0.6s}.monkey-card:nth-child(5){animation-delay:0.8s}
@keyframes monkeyBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-8rpx)}}
.monkey-card-emoji { font-size:40rpx; }
.monkey-card-label { font-size:20rpx;color:#6B5B4E; }
