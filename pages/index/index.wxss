.container { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; background: #F5F0E8; }

/* ===== 背景 ===== */
.bg-mountain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.06; pointer-events: none; }
.bg-mountain-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1; background: linear-gradient(180deg, rgba(245,240,232,0.3) 0%, rgba(235,225,210,0.15) 50%, rgba(230,220,200,0.25) 100%); pointer-events: none; }

/* ===== 🆕 欢迎引导遮罩 ===== */
.welcome-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 999; display: flex; flex-direction: column; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: opacity 0.8s ease;
}
.welcome-overlay.show { opacity: 1; pointer-events: auto; }
.wc-bg-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.4; }
.wc-bg-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 1; background: linear-gradient(180deg, rgba(245,240,232,0.5) 0%, rgba(235,225,210,0.6) 40%, rgba(230,220,200,0.85) 100%); }
.wc-cloud { position: absolute; top: 60rpx; left: 0; width: 200rpx; height: 200rpx; z-index: 2; opacity: 0.06; pointer-events: none; animation: mistDrift 8s ease-in-out infinite; }
.welcome-card { width: 580rpx; padding: 0; display: flex; flex-direction: column; align-items: center; position: relative; z-index: 3; animation: welcomeCardIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards; }
@keyframes welcomeCardIn { from { opacity: 0; transform: translateY(60rpx) scale(0.92); } to { opacity: 1; transform: translateY(0) scale(1); } }
.wc-card-inner { width: 100%; padding: 50rpx 40rpx 36rpx; background: rgba(255,248,245,0.92); backdrop-filter: blur(16rpx); border: 1.5rpx solid rgba(201,169,110,0.1); border-radius: 36rpx; display: flex; flex-direction: column; align-items: center; }
.wc-greeting { font-size: 38rpx; font-weight: 800; color: #8B7355; letter-spacing: 6rpx; margin-bottom: 16rpx; text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.wc-divider { width: 80rpx; height: 2rpx; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.3), transparent); margin-bottom: 28rpx; }
.wc-lines { display: flex; flex-direction: column; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.wc-line { font-size: 28rpx; color: #5C4A3A; text-align: center; line-height: 1.7; letter-spacing: 2rpx; }
.wc-disclaimer { font-size: 22rpx; color: #B0A090; font-style: italic; margin-bottom: 32rpx; }
.wc-btn { padding: 22rpx 80rpx; border-radius: 40rpx; background: linear-gradient(135deg, rgba(201,169,110,0.2) 0%, rgba(160,130,90,0.1) 100%); border: 1.5rpx solid rgba(201,169,110,0.25); transition: all 0.2s; }
.wc-btn:active { background: rgba(201,169,110,0.3); transform: scale(0.96); }
.wc-btn text { font-size: 30rpx; color: #8B7355; font-weight: 700; letter-spacing: 6rpx; }
.wc-skip { font-size: 20rpx; color: #C0B0A0; margin-top: 20rpx; letter-spacing: 2rpx; }

/* ===== 顶部品牌 ===== */
.header-section { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; padding-top: 80rpx; margin-bottom: 16rpx; }
.header-logo { width: 100rpx; height: 100rpx; border-radius: 22rpx; margin-bottom: 12rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }
.header-title { font-size: 36rpx; font-weight: 800; color: #2A3D35; letter-spacing: 6rpx; margin-bottom: 6rpx; }
.header-sub { font-size: 24rpx; color: #8B7355; letter-spacing: 4rpx; }

/* 连续天数标签 */
.streak-tag { display: flex; align-items: center; gap: 6rpx; margin-top: 12rpx; padding: 6rpx 18rpx; background: linear-gradient(135deg, #4A7A5A, #3A6A4A); border-radius: 20rpx; }
.streak-icon { font-size: 22rpx; }
.streak-text { font-size: 22rpx; color: #FFF8F5; font-weight: 500; }

/* ===== 图鉴进度卡片 ===== */
.album-card { width: 90%; max-width: 680rpx; margin: 0 auto 20rpx; padding: 20rpx 24rpx; background: #FFF8F5; border-radius: 16rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04); position: relative; z-index: 2; }
.album-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.album-card-left { display: flex; align-items: center; gap: 8rpx; }
.album-icon { font-size: 28rpx; }
.album-title { font-size: 26rpx; font-weight: 600; color: #2A3D35; }
.album-count { font-size: 26rpx; font-weight: 700; color: #C9A96E; }
.album-arrow { font-size: 22rpx; color: #8B7355; }
.album-progress-bar { width: 100%; height: 8rpx; background: #E8E0D0; border-radius: 4rpx; margin-bottom: 8rpx; overflow: hidden; }
.album-progress-fill { height: 100%; background: linear-gradient(90deg, #C9A96E, #A0522D); border-radius: 4rpx; transition: width 0.5s ease; }
.album-hint { font-size: 20rpx; color: #A09080; }

/* ===== 精选测试入口（3卡片横排）===== */
.featured-grid { display: flex; justify-content: center; gap: 16rpx; padding: 0 24rpx; margin-bottom: 24rpx; position: relative; z-index: 2; }
.feat-card { width: 210rpx; padding: 16rpx; background: #FFF8F5; border-radius: 16rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); display: flex; flex-direction: column; align-items: flex-start; }
.feat-card:active { transform: scale(0.97); opacity: 0.9; }
.feat-card-top { display: flex; align-items: center; justify-content: space-between; width: 100%; margin-bottom: 10rpx; }
.feat-icon { font-size: 36rpx; }
.feat-tag { font-size: 18rpx; color: #FFF8F5; padding: 2rpx 10rpx; border-radius: 8rpx; }
.feat-name { font-size: 26rpx; font-weight: 700; color: #2A3D35; margin-bottom: 6rpx; }
.feat-desc { font-size: 20rpx; color: #8B7355; line-height: 1.4; margin-bottom: 10rpx; flex: 1; }
.feat-enter { font-size: 20rpx; color: #C9A96E; align-self: flex-end; }

/* ===== 核心区：不知道怎么选 + 随缘一测 ===== */
.core-section { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; padding: 20rpx 60rpx; margin-bottom: 16rpx; }
.core-question { font-size: 28rpx; color: #5C4A3A; letter-spacing: 2rpx; margin-bottom: 8rpx; }
.core-hint { font-size: 24rpx; color: #A09080; text-align: center; line-height: 1.6; letter-spacing: 2rpx; font-style: italic; margin-bottom: 20rpx; }
.core-subhint { font-size: 20rpx; color: #B0A090; text-align: center; margin-top: 12rpx; }

.core-btn-wrap { position: relative; width: 280rpx; height: 280rpx; display: flex; align-items: center; justify-content: center; }
/* 外圈旋转的大阴阳鱼 */
.taiji-ring {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 0; display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: radial-gradient(circle, transparent 42%, rgba(201,169,110,0.08) 46%, transparent 50%);
  animation: taijiRotate 10s linear infinite;
}
.taiji-icon {
  font-size: 180rpx; opacity: 0.15; color: #C9A96E;
}
@keyframes taijiRotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.core-btn {
  position: relative; z-index: 1;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, rgba(201,169,110,0.15) 0%, rgba(160,140,100,0.08) 100%);
  border: 1.5rpx solid rgba(201,169,110,0.25);
  transition: all 0.3s;
  overflow: hidden;
}
.core-btn:active { background: rgba(201,169,110,0.2); transform: scale(0.95); }
.core-btn-text { position: relative; z-index: 2; font-size: 32rpx; color: #8B7355; font-weight: 700; letter-spacing: 6rpx; }

/* ===== 全部道法（折叠区）===== */
.all-tests-bar { display: flex; align-items: center; justify-content: center; gap: 10rpx; padding: 16rpx 0; margin: 0 auto 16rpx; width: 90%; max-width: 680rpx; background: #FFF8F5; border-radius: 12rpx; position: relative; z-index: 2; }
.all-tests-bar:active { opacity: 0.8; }
.all-tests-icon { font-size: 26rpx; }
.all-tests-text { font-size: 26rpx; font-weight: 600; color: #2A3D35; }
.all-tests-arrow { font-size: 22rpx; color: #8B7355; transition: transform 0.3s; }
.all-tests-arrow.up { transform: rotate(180deg); }

.all-tests-grid { display: none; flex-wrap: wrap; justify-content: center; gap: 16rpx; padding: 0 24rpx 24rpx; position: relative; z-index: 2; }
.all-tests-grid.show { display: flex; }
.all-test-item { width: 140rpx; padding: 16rpx 8rpx; background: #FFF8F5; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; gap: 6rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.all-test-item:active { opacity: 0.8; }
.all-test-icon { font-size: 36rpx; }
.all-test-name { font-size: 22rpx; color: #2A3D35; }

/* ===== 底部工具条（4项）===== */
.bottom-bar { position: relative; z-index: 2; display: flex; justify-content: center; gap: 50rpx; padding: 30rpx 0 20rpx; width: 100%; border-top: 1rpx solid rgba(201,169,110,0.12); }
.bb-item { display: flex; flex-direction: column; align-items: center; gap: 6rpx; position: relative; }
.bb-item:active { opacity: 0.6; }
.bb-main { min-width: 100rpx; }
.bb-icon { font-size: 40rpx; }
.bb-label { font-size: 22rpx; color: #8B7355; font-weight: 500; }
.bb-dot { position: absolute; top: -4rpx; right: 16rpx; width: 12rpx; height: 12rpx; border-radius: 50%; background: #C9A96E; animation: bbDotPulse 2s ease-in-out infinite; }
@keyframes bbDotPulse { 0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(1.6)}}

/* ===== 底部法律信息 ===== */
.bottom-legal { position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; padding: 8rpx 40rpx 40rpx; gap: 4rpx; }
.disclaimer-text { font-size: 18rpx; color: #C0B0A0; text-align: center; }
.icp-text { font-size: 16rpx; color: #D0C0B0; }

/* ===== 隐私协议弹窗 ===== */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 9999; display: flex; align-items: center; justify-content: center; }
.modal-card { width: 560rpx; max-height: 75vh; overflow-y: auto; padding: 40rpx 32rpx; background: #FFF8F5; border-radius: 24rpx; box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08); display: flex; flex-direction: column; align-items: center; }
.modal-icon { font-size: 52rpx; margin-bottom: 10rpx; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #2A3D35; margin-bottom: 8rpx; letter-spacing: 2rpx; }
.modal-desc { font-size: 24rpx; color: #6B5D4E; line-height: 1.6; text-align: center; display: block; }
.modal-links { display: flex; gap: 20rpx; margin: 14rpx 0; }
.modal-link { font-size: 24rpx; color: #C9A96E; padding: 8rpx 16rpx; border-bottom: 1rpx solid rgba(201,169,110,0.2); }
.modal-confirm { width: 60%; padding: 20rpx 0; text-align: center; font-size: 28rpx; font-weight: 700; color: #FFF8F5; background: linear-gradient(135deg, #C9A96E, #8B7355); border-radius: 40rpx; margin: 14rpx 0 8rpx; }
.modal-confirm:active { opacity: 0.85; }
.modal-hint { font-size: 20rpx; color: rgba(216,208,192,0.25); }
.btn-gold { }

/* ===== 次数用完弹窗 ===== */
.quota-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: flex-end; justify-content: center; }
.quota-card { width: 100%; background: #FFF8F5; border-radius: 32rpx 32rpx 0 0; padding: 32rpx 28rpx 40rpx; max-height: 70vh; overflow-y: auto; animation: slideUp 0.35s ease-out; }
.quota-header { display: flex; align-items: center; justify-content: center; gap: 10rpx; margin-bottom: 24rpx; }
.quota-icon { font-size: 40rpx; }
.quota-title { font-size: 30rpx; font-weight: 700; color: #2A3D35; letter-spacing: 2rpx; }
.quota-body { display: flex; flex-direction: column; gap: 14rpx; }
.quota-option { display: flex; align-items: center; gap: 14rpx; padding: 22rpx 18rpx; background: #F5F0E8; border-radius: 18rpx; border: 1rpx solid rgba(201,169,110,0.08); }
.qo-icon { font-size: 36rpx; flex-shrink: 0; width: 48rpx; text-align: center; }
.qo-text-group { flex: 1; }
.qo-label { font-size: 26rpx; color: #2A3D35; font-weight: 600; display: block; }
.qo-desc { font-size: 20rpx; color: #8B7355; margin-top: 4rpx; display: block; }
.qo-countdown { font-size: 20rpx; color: #C9A96E; margin-top: 4rpx; display: block; }
.qo-badge { font-size: 18rpx; color: #FFF8F5; background: linear-gradient(135deg, #C9A96E, #A0522D); padding: 4rpx 14rpx; border-radius: 20rpx; flex-shrink: 0; }
.qo-share-btn { width: 120rpx; font-size: 22rpx; color: #C9A96E; background: rgba(201,169,110,0.08); border: 1rpx solid rgba(201,169,110,0.15); border-radius: 12rpx; padding: 8rpx 0; text-align: center; flex-shrink: 0; }
.quota-footer { display: flex; gap: 14rpx; margin-top: 22rpx; }
.quota-btn { flex: 1; text-align: center; padding: 20rpx 0; border-radius: 20rpx; font-size: 26rpx; font-weight: 600; }
.quota-btn-secondary { color: #8B7355; background: #F5F0E8; border: 1rpx solid rgba(201,169,110,0.1); }
.quota-btn-primary { color: #FFF8F5; background: linear-gradient(135deg, #C9A96E, #A0522D); box-shadow: 0 6rpx 20rpx rgba(160,82,45,0.2); }

/* ===== 动画 ===== */
@keyframes mistDrift { 0%, 100% { transform: translateX(0); opacity: 0.6; } 50% { transform: translateX(30rpx); opacity: 0.3; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(60rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* ============================================================ */
/* 新手引导弹窗 */
/* ============================================================ */
.tutorial-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9998; display: flex; align-items: center; justify-content: center;
  background: rgba(0,0,0,0.55);
  opacity: 0; pointer-events: none;
  transition: opacity 0.4s ease;
}
.tutorial-overlay.show { opacity: 1; pointer-events: auto; }

.tutorial-card {
  width: 600rpx; padding: 48rpx 36rpx 36rpx;
  background: #FFF8F5;
  border-radius: 32rpx;
  border: 1.5rpx solid rgba(201,169,110,0.12);
  display: flex; flex-direction: column; align-items: center;
  animation: tutCardIn 0.5s ease-out;
  max-height: 85vh; overflow-y: auto;
}
@keyframes tutCardIn { from { opacity: 0; transform: translateY(50rpx) scale(0.93); } to { opacity: 1; transform: translateY(0) scale(1); } }

.tut-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 32rpx; }
.tut-title { font-size: 40rpx; font-weight: 800; color: #8B7355; letter-spacing: 6rpx; }
.tut-sub { font-size: 24rpx; color: #B0A090; margin-top: 8rpx; letter-spacing: 2rpx; }

.tut-steps { width: 100%; min-height: 260rpx; position: relative; margin-bottom: 20rpx; }

.tut-step {
  display: none;
  flex-direction: column; align-items: center; gap: 16rpx;
  padding: 24rpx 20rpx;
  animation: tutStepIn 0.35s ease-out;
}
.tut-step.active { display: flex; }
@keyframes tutStepIn { from { opacity: 0; transform: translateX(30rpx); } to { opacity: 1; transform: translateX(0); } }

.tut-icon-wrap {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, rgba(201,169,110,0.12), rgba(160,130,90,0.06));
  border: 1.5rpx solid rgba(201,169,110,0.2);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 8rpx;
}
.tut-icon-large { font-size: 48rpx; }

.tut-step-title { font-size: 28rpx; font-weight: 700; color: #8B7355; letter-spacing: 3rpx; }

.tut-step-desc { font-size: 26rpx; color: #5C4A3A; text-align: center; line-height: 1.7; padding: 0 10rpx; }
.tut-highlight { color: #C9A96E; font-weight: 600; }

.tut-dots { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.tut-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #D8D0C0; transition: all 0.3s; }
.tut-dot.active { background: #C9A96E; width: 36rpx; border-radius: 7rpx; }

.tut-actions { display: flex; gap: 20rpx; margin-bottom: 16rpx; }
.tut-btn-prev, .tut-btn-next {
  padding: 18rpx 44rpx; border-radius: 36rpx;
  font-size: 26rpx; font-weight: 600; letter-spacing: 2rpx;
  border: 1.5rpx solid rgba(201,169,110,0.2);
  color: #8B7355;
  background: rgba(201,169,110,0.06);
  transition: all 0.2s;
}
.tut-btn-prev:active, .tut-btn-next:active { background: rgba(201,169,110,0.15); }

.tut-btn-done {
  padding: 20rpx 80rpx; border-radius: 40rpx;
  font-size: 30rpx; font-weight: 700; letter-spacing: 4rpx;
  color: #FFF8F5;
  background: linear-gradient(135deg, #C9A96E, #8B7355);
  box-shadow: 0 6rpx 20rpx rgba(160,130,90,0.25);
  transition: all 0.2s;
}
.tut-btn-done:active { transform: scale(0.95); opacity: 0.85; }

.tut-skip { font-size: 22rpx; color: #C0B0A0; letter-spacing: 2rpx; padding: 8rpx; }

/* ============================================================ */
/* 浮动帮助按钮 */
/* ============================================================ */
.help-float {
  position: fixed; bottom: 200rpx; right: 28rpx; z-index: 900;
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,248,245,0.9);
  border: 1.5rpx solid rgba(201,169,110,0.25);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none; transform: scale(0.5);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.help-float.show { opacity: 1; pointer-events: auto; transform: scale(1); }
.help-float:active { transform: scale(0.9); }
.help-float-icon {
  font-size: 34rpx; font-weight: 700; color: #C9A96E;
  font-family: Georgia, serif; font-style: italic;
}
