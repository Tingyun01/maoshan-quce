.container { min-height: 100vh; padding: 0 24rpx 40rpx; background: linear-gradient(175deg, #3D5E4E 0%, #2A3D35 38%, #1A2D25 100%); }

/* 顶部统计 */
.album-header { margin: 20rpx 0; }
.album-title { font-size: 34rpx; font-weight: bold; color: #E8D0C0; display: block; }
.album-sub { font-size: 24rpx; color: rgba(232,208,192,0.55); margin-top: 8rpx; display: block; }

.album-stats { display: flex; align-items: center; justify-content: center; background: rgba(245,240,230,0.08); border-radius: 20rpx; padding: 24rpx 20rpx; margin: 20rpx 0 12rpx; }
.as-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.as-num { font-size: 38rpx; font-weight: bold; color: #C9A96E; }
.as-label { font-size: 22rpx; color: rgba(232,208,192,0.55); margin-top: 4rpx; }
.as-divider { width: 2rpx; height: 48rpx; background: rgba(255,255,255,0.08); }

.album-progress { margin-bottom: 24rpx; }
.ap-track { width: 100%; height: 8rpx; background: rgba(255,255,255,0.1); border-radius: 999rpx; overflow: hidden; }
.ap-fill { height: 100%; background: linear-gradient(90deg, #C9A96E, #FFD700); border-radius: 999rpx; transition: width 0.6s ease; }

/* 分组 */
.album-groups { margin-bottom: 28rpx; }
.group-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.group-name { font-size: 28rpx; font-weight: 600; color: #E8D0C0; }
.group-count { font-size: 22rpx; color: rgba(232,208,192,0.45); }

.group-grid { display: flex; flex-wrap: wrap; gap: 14rpx; }

/* 收藏卡片 */
.collect-card { width: 140rpx; height: 156rpx; border-radius: 16rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.collect-card.unlocked { background: linear-gradient(160deg, rgba(201,169,110,0.15), rgba(201,169,110,0.05)); border: 1rpx solid rgba(201,169,110,0.25); }
.collect-card.locked { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.06); }
.collect-card:active { transform: scale(0.94); opacity: 0.85; }

.cc-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(18,24,20,0.5); display: flex; align-items: center; justify-content: center; z-index: 1; border-radius: 16rpx; }
.cc-lock-icon { font-size: 36rpx; }

.cc-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.cc-name { font-size: 20rpx; color: rgba(232,208,192,0.7); text-align: center; line-height: 1.3; max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 大图详情浮层 */
.detail-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 100; animation: fadeIn 0.2s ease; }
.detail-card { width: 500rpx; background: #2A3D35; border-radius: 24rpx; overflow: hidden; box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.5); position: relative; }
.detail-image { width: 100%; height: 400rpx; display: block; }

/* 品牌遮挡层 — 右下角覆盖水印，防盗版 */
.detail-brand-bar {
  position: absolute;
  bottom: 80rpx;
  right: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx 10rpx 12rpx;
  background: rgba(18,24,20,0.7);
  border-radius: 12rpx 0 0 12rpx;
  backdrop-filter: blur(4px);
  z-index: 10;
}
.detail-qrcode {
  width: 40rpx;
  height: 40rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}
.detail-brand-texts {
  display: flex;
  flex-direction: column;
}
.detail-brand-name {
  font-size: 20rpx;
  font-weight: bold;
  color: #C9A96E;
  line-height: 1.2;
}
.detail-brand-sub {
  font-size: 16rpx;
  color: rgba(201,169,110,0.6);
  line-height: 1.2;
}

.detail-info { padding: 24rpx; text-align: center; }
.detail-testname { font-size: 24rpx; color: rgba(232,208,192,0.55); display: block; }
.detail-typename { font-size: 32rpx; font-weight: bold; color: #E8D0C0; margin-top: 8rpx; display: block; }
.detail-daojing { font-size: 22rpx; color: rgba(201,169,110,0.5); display: block; font-style: italic; margin-top: 12rpx; padding: 0 20rpx; line-height: 1.5; }
.detail-draw { display: flex; align-items: center; justify-content: center; gap: 8rpx; margin-top: 16rpx; padding: 14rpx; background: rgba(201,169,110,0.08); border-radius: 12rpx; }
.detail-draw:active { opacity: 0.7; }
.draw-icon { font-size: 28rpx; }
.draw-text { font-size: 24rpx; color: #C9A96E; }
.detail-close { padding: 20rpx; text-align: center; font-size: 26rpx; color: rgba(232,208,192,0.5); border-top: 1rpx solid rgba(255,255,255,0.06); }

/* 抽签弹窗 */
.lot-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 110; animation: fadeIn 0.2s ease; }
.lot-card { width: 440rpx; background: #2A3D35; border: 2rpx solid rgba(201,169,110,0.3); border-radius: 24rpx; padding: 40rpx 32rpx 32rpx; display: flex; flex-direction: column; align-items: center; box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.5); animation: slideUp 0.3s ease; }
.lot-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.lot-title { font-size: 32rpx; font-weight: bold; color: #C9A96E; margin-bottom: 12rpx; text-align: center; }
.lot-meaning { font-size: 24rpx; color: rgba(232,208,192,0.7); text-align: center; line-height: 1.6; margin-bottom: 24rpx; }
.lot-close { padding: 16rpx 48rpx; background: rgba(201,169,110,0.15); border-radius: 999rpx; font-size: 24rpx; color: #C9A96E; }
.lot-close:active { opacity: 0.7; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
