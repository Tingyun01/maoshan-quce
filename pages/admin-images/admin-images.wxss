.admin-page {
  min-height: 100vh;
  background: #1a2a1a;
  color: #fff;
  padding-bottom: 100rpx;
}

.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(0,0,0,0.4);
}
.back-btn { font-size: 28rpx; color: rgba(255,255,255,0.6); }
.title { font-size: 32rpx; font-weight: bold; color: #ffe4a0; }
.placeholder { width: 80rpx; }

.stats-bar {
  display: flex; gap: 16rpx; padding: 20rpx 24rpx;
}
.stat-item {
  flex: 1; text-align: center;
  padding: 16rpx 0;
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
}
.stat-item.ok { background: rgba(60,180,80,0.12); border: 1rpx solid rgba(60,180,80,0.25); }
.stat-item.err { background: rgba(220,60,60,0.12); border: 1rpx solid rgba(220,60,60,0.25); }
.stat-num { display: block; font-size: 44rpx; font-weight: bold; }
.stat-label { display: block; font-size: 22rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; }

.action-row {
  display: flex; gap: 12rpx; padding: 0 24rpx 16rpx;
  flex-wrap: wrap;
}
.btn {
  font-size: 24rpx; color: #fff;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 12rpx 20rpx;
  line-height: 1.2;
}
.btn.primary {
  background: linear-gradient(135deg, #c4956a, #8b5a3a);
  border-color: rgba(196,149,106,0.4);
}
.btn.small { font-size: 22rpx; padding: 8rpx 16rpx; }

.loading-box {
  text-align: center; padding: 60rpx 0;
}
.loading-text { display: block; font-size: 28rpx; color: rgba(255,255,255,0.6); }
.loading-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,0.3); margin-top: 8rpx; }

.result-list {
  padding: 0 24rpx;
  max-height: calc(100vh - 420rpx);
}
.image-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
}
.image-row.ok { background: rgba(60,180,80,0.06); border: 1rpx solid rgba(60,180,80,0.12); }
.image-row.missing { background: rgba(220,60,60,0.08); border: 1rpx solid rgba(220,60,60,0.18); }

.row-left { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; }
.row-status { font-size: 28rpx; flex-shrink: 0; }
.row-info { display: flex; flex-direction: column; gap: 2rpx; min-width: 0; }
.row-name {
  font-size: 26rpx; font-weight: bold; color: #fff;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.row-use { font-size: 20rpx; color: rgba(255,255,255,0.35); }
.row-right { flex-shrink: 0; max-width: 180rpx; }
.row-err { font-size: 18rpx; color: rgba(255,100,100,0.7); word-break: break-all; }

.empty-box { text-align: center; padding: 80rpx 0; }
.empty-text { font-size: 28rpx; color: rgba(255,255,255,0.3); }
