<view class="container {{themeClass}} page-enter">
  <!-- 背景 -->
  <image class="quiz-bg" src="/images/仙山2.jpg" mode="aspectFill"></image>
  <view class="quiz-bg-overlay"></view>
  <image class="quiz-cloud" src="/images/大祥云.jpg" mode="aspectFit"></image>

  <!-- ===== 加载中：道家箴言 ===== -->
  <view class="tao-loading {{showLoading ? 'show' : ''}}" wx:if="{{showLoading}}">
    <view class="tl-card">
      <text class="tl-icon">☯</text>
      <text class="tl-quote">{{taoQuote}}</text>
      <view class="tl-divider"></view>
      <text class="tl-sub">道法自然 · 稍候片刻</text>
      <view class="tl-dots">
        <view class="tl-dot"></view><view class="tl-dot"></view><view class="tl-dot"></view>
      </view>
    </view>
  </view>

  <!-- 顶部导航 -->
  <view class="quiz-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="quiz-top-bar">
      <view class="quiz-back" bindtap="goBack">
        <text class="qb-arrow">←</text>
        <text class="qb-text">退出</text>
      </view>
      <text class="quiz-name">{{testName}}</text>
      <view class="quiz-back-placeholder"></view>
    </view>
    <!-- 进度条改进：分段进度点 -->
    <view class="quiz-progress">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{questions.length > 0 ? (currentIndex / questions.length) * 100 : 0}}%"></view>
      </view>
      <text class="progress-text">{{currentIndex + 1}}/{{questions.length}}</text>
    </view>
  </view>

  <!-- 单题专注模式 -->
  <view class="quiz-card-area">
    <view class="quiz-card {{cardAnim}}" wx:if="{{currentQuestion}}">
      <!-- 题号标识 -->
      <view class="qc-header">
        <text class="qc-num">第{{currentIndex + 1}}题</text>
        <text class="qc-type" wx:if="{{currentTypeHint}}">{{currentTypeHint}}</text>
      </view>

      <!-- 心念语：观主途中赠言 -->
      <view class="heart-msg" wx:if="{{heartMsg}}">
        <text class="heart-text">{{heartMsg}}</text>
      </view>

      <!-- 题目文字 -->
      <text class="qc-text">{{currentQuestion.text}}</text>

      <!-- 选项区 -->
      <view class="qc-options">
        <view wx:for="{{currentQuestion.options}}" wx:for-item="opt" wx:key="index"
              class="qc-opt {{selectedMap[currentQuestion.id] === index ? 'selected' : ''}}"
              bindtap="selectOption" data-qid="{{currentQuestion.id}}" data-idx="{{index}}"
              style="animation-delay: {{index * 0.06}}s">
          <view class="qc-dot {{selectedMap[currentQuestion.id] === index ? 'on' : ''}}"></view>
          <text class="qc-label">{{opt.text}}</text>
          <text class="qc-check" wx:if="{{selectedMap[currentQuestion.id] === index}}">✓</text>
        </view>
      </view>
    </view>

    <!-- 提示文字 -->
    <text class="quiz-hint" wx:if="{{!currentQuestion}}">题目加载中...</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="quiz-footer">
    <view class="qf-nav" wx:if="{{currentIndex > 0}}" bindtap="prevQuestion">
      <text class="qf-nav-icon">‹</text>
      <text class="qf-nav-text">上一题</text>
    </view>
    <view class="qf-spacer" wx:else></view>

    <!-- 进度提示 -->
    <text class="qf-progress-hint">{{selectedCount}}/{{questions.length}} 已答</text>

    <view class="qf-submit-btn {{selectedCount >= questions.length ? 'active' : 'inactive'}}"
          bindtap="nextOrSubmit">
      <text>✨ 查看结果</text>
    </view>
  </view>

  <!-- ===== 次数用完弹窗 ===== -->
  <view class="quota-mask" wx:if="{{showQuotaModal}}">
    <view class="quota-card">
      <view class="quota-header">
        <text class="quota-icon">🌙</text>
        <text class="quota-title">次数用完了~</text>
      </view>
      <view class="quota-body">
        <view class="quota-option quota-option-wait">
          <text class="qo-icon">⏳</text>
          <view class="qo-text-group">
            <text class="qo-label">小憩片刻</text>
            <text class="qo-desc">30分钟恢复1次 · 上限5次</text>
            <text class="qo-countdown" wx:if="{{quotaNextRecover}}">{{quotaNextRecover}} 后恢复</text>
          </view>
        </view>
        <view class="quota-option quota-option-ad" bindtap="onWatchAd">
          <text class="qo-icon">📺</text>
          <view class="qo-text-group">
            <text class="qo-label">看个广告 → 立刻爽 2 次</text>
            <text class="qo-desc">今日还可看 {{quotaAdRemaining}} 次</text>
          </view>
          <text class="qo-badge">🔥推荐</text>
        </view>
        <view class="quota-option quota-option-share">
          <text class="qo-icon">💬</text>
          <view class="qo-text-group">
            <text class="qo-label">分享好友 → 一起测更欢乐 +1次</text>
            <text class="qo-desc">今日还可邀 {{quotaShareRemaining}} 位</text>
          </view>
          <button class="qo-share-btn" open-type="share">分享</button>
        </view>
      </view>
      <view class="quota-footer">
        <view class="quota-btn quota-btn-secondary" bindtap="onWaitLater">好，我等一下来</view>
        <view class="quota-btn quota-btn-primary" bindtap="onWatchAd">立刻看广告续命🔥</view>
      </view>
    </view>
  </view>

  <!-- ===== 退出确认弹窗 ===== -->
  <view class="exit-mask" wx:if="{{showExitModal}}">
    <view class="exit-card">
      <text class="exit-icon">⚠️</text>
      <text class="exit-title">确定退出测试？</text>
      <text class="exit-desc">已经答了 {{selectedCount}}/{{questions.length}} 题，退出后要重新开始哦~</text>
      <view class="exit-actions">
        <view class="exit-btn exit-btn-cancel" bindtap="cancelExit">继续答题</view>
        <view class="exit-btn exit-btn-confirm" bindtap="confirmExit">确定退出</view>
      </view>
    </view>
  </view>
</view>
