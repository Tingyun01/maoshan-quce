.container { min-height: 100vh; padding: 0 24rpx 40rpx; background: linear-gradient(175deg, #2A3D35 0%, #1A2D25 38%, #1A2D25 100%); }
.dungeon-header { margin: 20rpx 0; }
.dungeon-title { font-size: 34rpx; font-weight: bold; color: #E8D0C0; display: block; }
.dungeon-sub { font-size: 22rpx; color: rgba(232,208,192,0.5); margin-top: 6rpx; display: block; }

.dungeon-list { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.dungeon-card { display: flex; align-items: center; padding: 24rpx; background: rgba(245,240,230,0.06); border-radius: 20rpx; gap: 16rpx; border: 1rpx solid rgba(201,169,110,0.08); }
.dungeon-card:active { transform: scale(0.98); opacity: 0.85; }
.dungeon-card.locked { opacity: 0.5; }
.dc-left { flex-shrink: 0; }
.dc-icon { font-size: 44rpx; }
.dc-mid { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.dc-name { font-size: 28rpx; font-weight: 600; color: #E8D0C0; }
.dc-desc { font-size: 20rpx; color: rgba(232,208,192,0.45); line-height: 1.4; }
.dc-tags { display: flex; gap: 8rpx; margin-top: 4rpx; }
.dc-tag { font-size: 18rpx; color: rgba(201,169,110,0.4); padding: 2rpx 10rpx; border: 1rpx solid rgba(201,169,110,0.12); border-radius: 999rpx; }
.dc-right { flex-shrink: 0; text-align: right; display: flex; flex-direction: column; gap: 4rpx; }
.dc-status { font-size: 20rpx; color: #7A9E7A; }
.dc-status.locked { color: rgba(232,208,192,0.3); }
.dc-master { font-size: 18rpx; color: rgba(232,208,192,0.3); }

/* 镇山四宝 */
.treasure-section { margin-bottom: 32rpx; }
.treasure-title { font-size: 28rpx; font-weight: 600; color: #C9A96E; display: block; margin-bottom: 4rpx; }
.treasure-sub { font-size: 20rpx; color: rgba(232,208,192,0.4); display: block; margin-bottom: 16rpx; }
.treasure-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.treasure-item { padding: 20rpx; background: rgba(245,240,230,0.06); border-radius: 16rpx; border: 1rpx solid rgba(201,169,110,0.08); text-align: center; }
.tr-icon { font-size: 36rpx; display: block; margin-bottom: 8rpx; }
.tr-name { font-size: 24rpx; font-weight: 600; color: #E8D0C0; display: block; margin-bottom: 6rpx; }
.tr-desc { font-size: 18rpx; color: rgba(232,208,192,0.45); display: block; line-height: 1.4; margin-bottom: 8rpx; }
.tr-origin { font-size: 16rpx; color: rgba(201,169,110,0.3); display: block; margin-bottom: 6rpx; }
.tr-rarity { font-size: 16rpx; padding: 2rpx 10rpx; border-radius: 999rpx; display: inline-block; }
.tr-rarity.SSR { background: rgba(226,75,74,0.2); color: #F09595; }

/* 丹药配方 */
.recipe-section { margin-bottom: 32rpx; }
.recipe-title { font-size: 28rpx; font-weight: 600; color: #C9A96E; display: block; margin-bottom: 16rpx; }
.recipe-list { display: flex; flex-direction: column; gap: 12rpx; }
.recipe-item { display: flex; align-items: center; gap: 16rpx; padding: 16rpx; background: rgba(245,240,230,0.04); border-radius: 12rpx; }
.rp-name { font-size: 24rpx; font-weight: bold; color: #C9A96E; width: 80rpx; flex-shrink: 0; }
.rp-ingredients { font-size: 20rpx; color: rgba(232,208,192,0.5); flex-shrink: 0; }
.rp-effect { font-size: 18rpx; color: rgba(232,208,192,0.35); flex: 1; }
