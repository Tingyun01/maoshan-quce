.container { min-height: 100vh; padding: 88rpx 32rpx 60rpx; background: var(--ink); }
.page-title { font-size: 36rpx; font-weight: 800; color: #F5F0EB; text-align: center; display: block; }
.tao-divider { width: 80rpx; height: 2rpx; background: linear-gradient(90deg, transparent, var(--gold), transparent); margin: 12rpx auto; }
.section { margin: 24rpx 0; }
.stitle { font-size: 26rpx; font-weight: 600; color: #F5F0EB; display: block; margin-bottom: 8rpx; }
.sbody { font-size: 24rpx; color: rgba(245,240,235,0.6); line-height: 1.8; display: block; }
.footer-bar { text-align: center; font-size: 20rpx; color: rgba(245,240,235,0.25); padding: 36rpx 0 16rpx; }
