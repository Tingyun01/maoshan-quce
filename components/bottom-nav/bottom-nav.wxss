/* ===== 全局底部导航栏 ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(90, 154, 106, 0.12);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.bn-safe {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 8rpx 12rpx 4rpx;
}

.bn-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  padding: 6rpx 16rpx;
  min-width: 100rpx;
  transition: all 0.2s;
  border-radius: 12rpx;
}

.bn-icon {
  font-size: 38rpx;
  line-height: 1;
}

.bn-label {
  font-size: 20rpx;
  color: #9AAA9A;
  font-weight: 500;
  line-height: 1;
}

.bn-item.active .bn-label {
  color: #5A9A6A;
  font-weight: 700;
}

.bn-indicator {
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #5A9A6A;
}

.bn-item:active {
  background: rgba(90, 154, 106, 0.06);
}

/* iPhone 底部安全区 */
.bn-area {
  height: env(safe-area-inset-bottom, 0rpx);
  background: #FFFFFF;
}
